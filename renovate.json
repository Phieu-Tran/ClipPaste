{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "timezone": "Asia/Ho_Chi_Minh",
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Group all non-major updates into one weekly PR",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major dependencies"
    },
    {
      "description": "Major updates one at a time — React/Vite/Tailwind majors need manual migration",
      "matchUpdateTypes": ["major"],
      "prPriority": -1
    },
    {
      "description": "window-vibrancy is a pinned fork rev, bumped manually",
      "matchPackageNames": ["window-vibrancy"],
      "enabled": false
    }
  ]
}
