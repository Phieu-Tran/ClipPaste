# Normalize all text files to LF in the repo and on checkout (any OS).
# Without this, Windows checkouts get CRLF and `prettier --check`
# (endOfLine: lf) fails for every file in CI.
* text=auto eol=lf

# Binary assets — never normalize or diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
